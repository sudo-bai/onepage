{
  "manifest_version": 3,
  "name": "Onepage - Custom New Tab",
  "version": "2.1.0",
  "description": "A beautiful and functional custom new tab page",
  "chrome_url_overrides": {
    "newtab": "app/index.html"
  },
  "action": {
    "default_title": "Onepage"
  },
  "options_page": "options.html",
  "permissions": [
    "tabs"
  ],
  "host_permissions": [
    "https://t.alcy.cc/*",
    "https://tc.alcy.cc/*",
    "https://bing.biturl.top/*",
    "https://api.uomg.com/*",
    "https://api.bing.com/*",
    "https://api.iowen.cn/*"
  ]
}
